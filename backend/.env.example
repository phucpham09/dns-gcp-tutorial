# Bắt buộc khi không dùng DATABASE_URL
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
POSTGRES_DB=notes_db

# Luôn dùng localhost khi chạy Poetry trên máy (bootstrap, uvicorn). KHÔNG đặt db — hostname đó chỉ có trong mạng Docker.
# Docker Compose vẫn gán POSTGRES_HOST=db cho container api; không cần sửa dòng này cho Docker.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Tuỳ chọn: URL đầy đủ (bỏ qua POSTGRES_* khi ghép URL)
# DATABASE_URL=postgresql+asyncpg://app:change_me@localhost:5432/notes_db

# DB_ECHO=true
